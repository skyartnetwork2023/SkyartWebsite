---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import ContactSection from '@components/sections/misc/ContactSection.astro';
import { SITE } from '@data/constants';

const pageTitle: string = `Contact | ${SITE.title}`;
const metaDescription =
  'Have questions about street Wi-Fi, hotel Wi-Fi or campus connectivity? Reach out and let us discuss a tailored solution.';
const ogTitle = 'Contact Skyart Networks Limited';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': '#!',
    '@type': '#!',
    '@id': '#!',
    url: '#!',
    name: '#!',
    description:
      'Have questions about street Wi-Fi, hotel Wi-Fi or campus connectivity? Reach out and let us discuss a tailored solution.',
    isPartOf: {
      '@type': '#!',
      url: '#!',
      name: '#!',
      description:
        'Skyart Networks Limited offers dependable connectivity for streets, hotels and campuses with licensed ISP support.',
    },
    inLanguage: 'en-US',
  }}
>
  <ContactSection />
</MainLayout>
