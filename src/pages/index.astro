---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import ClientsSection from '@components/sections/landing/ClientsSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import PricingSection from '@components/sections/pricing/PricingSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import AnnouncementBanner from '@components/ui/banners/AnnouncementBanner.astro';
import heroImage from '@images/hero-image.avif';
import faqs from '@data/faqs.json';
import features from '@data/features.json';
import pricing from '@data/pricing.json';
import featureImage from '@images/features-image.avif';
import construction from '@images/construction-image.avif';
import tools from '@images/automated-tools.avif';
import dashboard from '@images/dashboard-image.avif';
import { partnersData } from '@/data_files/constants';

const avatarSrcs: Array<string> = [
  'https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
];
---

<MainLayout>
  <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Talk to Skyart Networks"
    url="/contact"
  />

  <HeroSection
    title=`Reliable Wi-Fi for <span
        class="text-yellow-500 dark:text-yellow-400">Streets, Hotels & Campuses</span>`
    subTitle="Skyart Networks Limited delivers street Wi-Fi, hotel Wi-Fi and campus Wi-Fi management with licensed ISP support."
    primaryBtn="Explore Services"
    primaryBtnURL="/services"
    secondaryBtn="Contact Skyart"
    secondaryBtnURL="/contact"
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.9</span> / 5`
    starCount={5}
    reviews=`Trusted by <span class="font-bold">local</span> network clients`
    src={heroImage}
    alt="Wi-Fi network equipment supporting public and private connectivity"
  />

  <ClientsSection
    title="Built for Connected Spaces"
    subTitle="From public access zones to hospitality and education environments, we create dependable Wi-Fi experiences."
    partners={partnersData}
  />

  <FeaturesGeneral
    title="Purpose-built ISP Services"
    subTitle="At Skyart Networks Limited, we help organisations stay connected with dependable street Wi-Fi, hotel Wi-Fi and campus Wi-Fi management tailored to each location."
    src={featureImage}
    alt="Wi-Fi services for connected communities"
    features={features}
  />

  <FeaturesNavs
    title=`Custom connectivity solutions for <span class="text-yellow-500 dark:text-yellow-400">streets, hotels and campuses</span>.`
    tabs={[
      {
        heading: 'Street Wi-Fi',
        content:
          'Deliver public access coverage for communities, estates, markets and business districts with dependable setup and managed bandwidth.',
        svg: 'tools',
        src: tools,
        alt: 'Wi-Fi access network equipment outdoors',
        first: true,
      },
      {
        heading: 'Hotel & Hospitality',
        content:
          'Create simple guest onboarding, secure access and centralised management for hotels, lodges and hospitality facilities.',
        svg: 'dashboard',
        src: dashboard,
        alt: 'Hotel guest Wi-Fi and management dashboard',
        second: true,
      },
      {
        heading: 'Campus Management',
        content:
          'Support large institutions with secure, monitored Wi-Fi services that keep students, staff and visitors connected.',
        svg: 'house',
        src: construction,
        alt: 'Campus Wi-Fi support and access network',
      },
    ]}
  />

  <TestimonialsSection
    title="Fast, reliable network support"
    subTitle="Skyart Networks Limited makes setup simple and keeps your Wi-Fi environment running smoothly from deployment to ongoing support."
    testimonials={[
      {
        content:
          'Skyart Networks helped us launch reliable public Wi-Fi and their support has been outstanding from day one. The service is stable and easy to manage.',
        author: 'Amina Okafor',
        role: 'Operations Lead | Hospitality Group',
        avatarSrc:
          'https://images.unsplash.com/photo-1593104547489-5cfb3839a3b5?q=80&w=1453&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
      },
    ]}
    statistics={[
      {
        count: '24/7',
        description: 'network support for connected clients',
      },
      {
        count: '100%',
        description: 'focus on dependable Wi-Fi availability',
      },
      {
        count: 'Licensed',
        description: 'ISP operations with district application licence',
      },
      {
        count: 'Multi-site',
        description: 'deployment support for hotels and campuses',
      },
    ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Frequently<br />asked questions" faqs={faqs} />

  <HeroSectionAlt
    title="Let's connect your space"
    subTitle="Skyart Networks Limited is ready to help you deploy dependable internet access for streets, hotels and campuses."
    url="/contact"
  />
</MainLayout>
