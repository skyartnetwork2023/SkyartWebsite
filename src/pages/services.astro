---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

// Import necessary images
import blueprints from '@images/blueprints-image.avif';
import personWorking from '@images/person-working.avif';
import beforeAfter from '@images/before-after.avif';
import constructionWorkers from '@images/construction-workers.avif';
import aerialView from '@images/aerial-view.avif';
import usingTools from '@images/using-tools.avif';
import progressBuilding from '@images/progress-building.avif';
import underConstruction from '@images/under-construction.avif';
import { SITE } from '@data/constants';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Street Wi-Fi Deployment',
    subTitle:
      'We plan and install reliable public Wi-Fi for neighbourhoods, roads, markets and commercial zones, helping communities stay connected with simple access and consistent performance.',
    single: false,
    imgOne: blueprints,
    imgOneAlt: 'Network design and planning for a public Wi-Fi rollout.',
    imgTwo: personWorking,
    imgTwoAlt: 'Technician preparing a Wi-Fi deployment',
  },
  {
    isRightSection: false,
    title: 'Hotel & Hospitality Connectivity',
    subTitle:
      'Our hotel Wi-Fi solutions simplify guest access, support secure onboarding and give management teams central visibility over network usage and performance.',
    img: beforeAfter,
    imgAlt: 'Hotel Wi-Fi coverage and guest connectivity setup',
    btnExists: true,
    btnTitle: 'Book a Consultation',
    btnURL: '/contact',
  },
  {
    isRightSection: true,
    title: 'Campus Wi-Fi Management',
    subTitle:
      'We support campuses with managed Wi-Fi that keeps students, staff and visitors connected, while giving administrators control over users, bandwidth and access policies.',
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: 'Campus network support and installation',
    imgTwo: aerialView,
    imgTwoAlt: 'Aerial view of a connected campus environment',
  },
  {
    isRightSection: false,
    title: 'Ongoing Monitoring & Support',
    subTitle:
      'We provide continuous monitoring, troubleshooting and maintenance so your Wi-Fi network remains stable, secure and ready for growth.',
    img: usingTools,
    imgAlt: 'Technician monitoring network equipment',
  },
  {
    isRightSection: true,
    title: 'Licensed ISP Operations',
    subTitle:
      'Skyart Networks Limited is a registered ISP company with a district application licence, giving clients confidence in compliant, dependable connectivity solutions.',
    single: false,
    imgOne: progressBuilding,
    imgOneAlt: 'ISP infrastructure and network expansion',
    imgTwo: underConstruction,
    imgTwoAlt: 'Connectivity rollout in progress',
    btnExists: true,
    btnTitle: 'Get in Touch',
    btnURL: '/contact',
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'Skyart Networks Limited offers dependable Wi-Fi solutions for streets, hotels and campuses with licensed ISP support and tailored network management.';
const ogTitle = 'Wi-Fi Services | Skyart Networks Limited';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': '#!',
    '@type': '#!',
    '@id': '#!',
    url: '#!',
    name: '#!',
    description:
      'Skyart Networks Limited provides dependable Wi-Fi services for streets, hotels and campuses, from rollout planning to ongoing support and management.',
    isPartOf: {
      '@type': 'WebSite',
      url: '#!',
      name: '#!',
      description:
        'Skyart Networks Limited offers dependable connectivity for streets, hotels and campuses with licensed ISP support.',
    },
    inLanguage: 'en-US',
  }}
>
  {
    /* MainSection is the introductory section of the page, it also contains a CTA button */
  }
  <MainSection
    title="Connected Spaces, Built for Reliability"
    subTitle="At Skyart Networks Limited, we deliver professional Wi-Fi services for streets, hotels and campuses, supporting everything from site planning to ongoing network management."
    btnExists={true}
    btnTitle="Schedule a Consultation"
    btnURL="#"
  />
  {
    /* RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  */
  }
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  {/* FeaturesStats section showcases essential stats valuable to users */}
  <FeaturesStats
    title="By the Numbers"
    subTitle="Our commitment to reliable connectivity is reflected in every deployment we support. Skyart Networks Limited helps clients stay online with dependable Wi-Fi services and responsive support."
    mainStatTitle="100%"
    mainStatSubTitle="focus on dependable network access for every deployment"
    stats={[
      {
        stat: '24/7',
        description: 'support coverage',
      },
      {
        stat: 'Licensed',
        description: 'ISP operations',
      },
      {
        stat: 'Multi-site',
        description: 'deployment capability',
      },
    ]}
  />
</MainLayout>
